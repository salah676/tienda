generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  CLIENTE
}

enum PlanType {
  BRONCE
  ORO
  PREMIUM
  FREE
}

enum UnitType {
  PIEZA
  KILO
  GRAMO
  LITRO
}

enum PaymentMethod {
  TRANSFERENCIA
  WAFACASH
  CASHPLUS
}

enum PaymentStatus {
  PENDIENTE
  COMPLETADO
  FALLIDO
}

enum TenantStatus {
  ACTIVO
  SUSPENDIDO
  EXPIRADO
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  phone         String?
  photo         String?
  role          Role      @default(CLIENTE)
  tenantId      String?
  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

model Tenant {
  id                    String        @id @default(cuid())
  name                  String
  subdomain             String        @unique
  logo                  String?
  banner                String?
  description          String?
  primaryColor          String        @default("#000000")
  contactPhone          String?
  contactEmail          String?
  status                TenantStatus  @default(ACTIVO)
  planId                String?
  plan                  Plan?         @relation(fields: [planId], references: [id])
  subscriptionStart     DateTime?
  subscriptionExpires    DateTime?
  googleAdsEnabled      Boolean       @default(false)
  paymentGateways       Json          @default("[]")
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  users                 User[]
  clients               Client[]
  products              Product[]
  categories            Category[]
  debts                 Debt[]
  payments              Payment[]
  supportTickets        SupportTicket[]

  @@map("tenants")
}

model Plan {
  id                  String    @id @default(cuid())
  name                String
  type                PlanType
  price               Decimal   @db.Decimal(10, 2)
  durationDays        Int
  maxClients          Int       @default(100)
  maxProducts         Int       @default(50)
  features            Json      @default("[]")
  googleAdsEnabled    Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenants             Tenant[]

  @@map("plans")
}

model Category {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]

  @@unique([tenantId, name])
  @@map("categories")
}

model Product {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name        String
  description String?
  price       Decimal   @db.Decimal(10, 2)
  unitType    UnitType  @default(PIEZA)
  stock       Int?
  photo       String?
  barcode     String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  debtItems   DebtItem[]

  @@unique([tenantId, name])
  @@map("products")
}

model Client {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  phone       String
  photo       String?
  email       String?
  address     String?
  notes       String?
  totalDebt   Decimal   @default(0) @db.Decimal(10, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  debts       Debt[]
  payments    Payment[]

  @@unique([tenantId, phone])
  @@map("clients")
}

model Debt {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  totalAmount Decimal       @db.Decimal(10, 2)
  paidAmount  Decimal       @default(0) @db.Decimal(10, 2)
  status      DebtStatus    @default(PENDIENTE)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  items       DebtItem[]
  payments    Payment[]

  @@map("debts")
}

enum DebtStatus {
  PENDIENTE
  PARCIAL
  PAGADO
  CANCELADO
}

model DebtItem {
  id        String   @id @default(cuid())
  debtId    String
  debt      Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Decimal  @db.Decimal(10, 3)
  unitPrice Decimal  @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  @@map("debt_items")
}

model Payment {
  id              String         @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  debtId          String?
  debt            Debt?         @relation(fields: [debtId], references: [id], onDelete: SetNull)
  amount          Decimal       @db.Decimal(10, 2)
  method          PaymentMethod @default(TRANSFERENCIA)
  status          PaymentStatus @default(PENDIENTE)
  reference       String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("payments")
}

model SupportTicket {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      String
  subject     String
  status      TicketStatus  @default(ABIERTO)
  messages    TicketMessage[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("support_tickets")
}

enum TicketStatus {
  ABIERTO
  EN_PROCESO
  CERRADO
}

model TicketMessage {
  id          String   @id @default(cuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId      String
  content     String
  isAdmin     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("ticket_messages")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  tenantId    String?
  action      String
  entity      String
  entityId    String?
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@map("audit_logs")
}

model SyncQueue {
  id          String   @id @default(cuid())
  tenantId    String
  entity      String
  entityId    String
  action      String
  data        Json
  synced      Boolean  @default(false)
  createdAt   DateTime @default(now())
  syncedAt    DateTime?

  @@map("sync_queue")
}

model Settings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("settings")
}