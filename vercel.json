{
  "framework": "nextjs",
  "buildCommand": "cd apps/web && npm run build",
  "devCommand": "cd apps/web && npm run dev",
  "installCommand": "cd apps/web && npm install",
  "regions": ["iad1"],
  "github": {
    "enabled": true,
    "autoJobCancelation": true
  },
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1",
      "DATABASE_URL": "@database-url"
    }
  }
}