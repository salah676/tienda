{
  "framework": "nextjs",
  "buildCommand": "npm run build:web",
  "devCommand": "cd apps/web && npm run dev",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "github": {
    "enabled": true,
    "autoJobCancelation": true
  },
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1"
    }
  }
}